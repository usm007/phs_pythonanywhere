# App security
PHS_SECRET_KEY=replace-with-a-long-random-secret

# Batch delete password (used only for the batch delete students feature)
PHS_BATCH_DELETE_PASSWORD=phs

# Database mode: tidb | auto | sqlite
PHS_DB_MODE=tidb
PHS_DB_CONNECT_TIMEOUT=3

# TiDB connection
TIDB_HOST=your-tidb-host
TIDB_PORT=4000
TIDB_USER=your-tidb-username
TIDB_PASSWORD=your-tidb-password
TIDB_DATABASE=test

# Optional project path override (useful on hosting)
PHS_PROJECT_HOME=/home/your-username/PHS
